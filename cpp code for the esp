#include <Keypad.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

// LCD setup
LiquidCrystal_I2C lcd(0x27, 16, 2); // change to 0x3F if needed

// Motor pins
const int ENA = 25;   // PWM
const int IN1 = 26;
const int IN2 = 27;

// PWM setup
const int pwmChannel = 0;
const int pwmFreq = 20000;     // 20 kHz
const int pwmResolution = 8;   // 8-bit (0–255)

// Encoder pins
const int ENCODER_A = 32;
const int ENCODER_B = 33;
volatile long pulseCount = 0;
const int PPR = 20; // your encoder pulses per revolution

// Potentiometer
const int POT_PIN = 34;

// Keypad setup
const byte ROWS = 4, COLS = 4;
char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};
byte rowPins[ROWS] = {13, 12, 14, 15};
byte colPins[COLS] = {4, 5, 18, 19};
Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// Control variables
int targetRPM = 0;
float actualRPM = 0;
int motorDirection = 0;
int pwmOutput = 0;

// PID
float Kp = 12.0, Ki = 1.0, Kd = 2.0;
float integral = 0, lastError = 0;

unsigned long lastTime = 0;
const unsigned long interval = 1000; // ms

// Encoder ISR
void IRAM_ATTR encoderISR() {
  pulseCount++;
}

void brakeMotor() {
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, HIGH);
  ledcWrite(pwmChannel, 0);
}

void setDirection(int dir) {
  if (dir == 1) {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
  } else if (dir == -1) {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
  } else {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, LOW);
  }
}

void setup() {
  Serial.begin(115200);

  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);

 
  // Encoder setup
  pinMode(ENCODER_A, INPUT_PULLUP);
  pinMode(ENCODER_B, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(ENCODER_A), encoderISR, RISING);

  // LCD init
  lcd.init();
  lcd.backlight();
  lcd.setCursor(0,0);
  lcd.print("Motor Control");

  brakeMotor();
  lastTime = millis();
}

void loop() {
  // Read keypad
  char key = keypad.getKey();
  if (key) {
    if (key >= '0' && key <= '9') {
      targetRPM = targetRPM * 10 + (key - '0');
    } else if (key == '*') {
      Serial.printf("Target RPM set: %d\n", targetRPM);
    } else if (key == 'A') motorDirection = 1;
    else if (key == 'B') motorDirection = -1;
    else if (key == '0') {
      targetRPM = 0;
      motorDirection = 0;
      brakeMotor();
      Serial.println("Motor STOPPED");
    }
  }

  // Read potentiometer (optional speed control)
  int potValue = analogRead(POT_PIN);
  int potRPM = map(potValue, 0, 4095, 0, 210);
  if (potRPM > 0) targetRPM = potRPM;

  // Every interval: compute RPM and update PID
  unsigned long currentTime = millis();
  if (currentTime - lastTime >= interval) {
    noInterrupts();
    long pulses = pulseCount;
    pulseCount = 0;
    interrupts();

    actualRPM = (pulses / (float)PPR) * (60000.0 / interval);

    // PID
    float error = targetRPM - actualRPM;
    integral += error * (interval / 1000.0);
    if (integral > 200) integral = 200;
    if (integral < -200) integral = -200;
    float derivative = (error - lastError) / (interval / 1000.0);
    lastError = error;

    pwmOutput = (int)(Kp * error + Ki * integral + Kd * derivative);

    if (targetRPM == 0 || motorDirection == 0) {
      brakeMotor();
      pwmOutput = 0;
    } else {
      if (pwmOutput > 255) pwmOutput = 255;
      if (pwmOutput < 0) pwmOutput = 0;
      setDirection(motorDirection);
      ledcWrite(pwmChannel, pwmOutput);
    }

    // Debug
    Serial.printf("Target: %d | Actual: %.1f | PWM: %d\n", targetRPM, actualRPM, pwmOutput);

    // LCD update
    lcd.clear();
    lcd.setCursor(0,0);
    lcd.print("T:");
    lcd.print(targetRPM);
    lcd.print(" A:");
    lcd.print((int)actualRPM);
    lcd.setCursor(0,1);
    lcd.print("PWM:");
    lcd.print(pwmOutput);

    lastTime = currentTime;
  }
}
